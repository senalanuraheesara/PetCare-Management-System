MONGO_URI=
JWT_SECRET=

# Optional — defaults to 5000 if omitted
# PORT=5000

# Required once to create the first admin account (runs on server start if user does not exist)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# OTP via Gmail SMTP (recommended for production)
# EMAIL_USER=
# EMAIL_PASS=

# Optional — only for local testing; never enable in production (accepts unverified Google profile in body)
# ALLOW_INSECURE_GOOGLE_AUTH=false
